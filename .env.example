APP_NAME=AuctionChain
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Belgrade
APP_URL=http://localhost:8000

APP_LOCALE=sr
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ----- BAZA PODATAKA -----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auctionchain
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
CACHE_STORE=database

# ----- STRIPE (opciono: uplata karticom, test režim) -----
# Ključevi sa https://dashboard.stripe.com/test/apikeys
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_CURRENCY=rsd

# ----- GROQ AI (opciono: AI opisi i chatbot) -----
# Besplatan ključ sa https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ----- EMAIL (opciono: obaveštenja) -----
# Bez podešavanja, mejlovi se upisuju u storage/logs/laravel.log (MAIL_MAILER=log).
# Za pravi test inbox koristi Mailtrap (https://mailtrap.io) i postavi MAIL_MAILER=smtp.
MAIL_MAILER=log
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@auctionchain.test"
MAIL_FROM_NAME="${APP_NAME}"
